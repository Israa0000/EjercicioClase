<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.EjercicioClase">
        <activity
            android:name=".ui.theme.Productos"
            android:exported="false"
            android:label="@string/title_activity_productos"
            android:theme="@style/Theme.EjercicioClase" />
        <activity
            android:name=".ui.theme.Configuracion"
            android:exported="false"
            android:label="@string/title_activity_configuracion"
            android:theme="@style/Theme.EjercicioClase" />
        <activity
            android:name=".ui.theme.Login"
            android:exported="false"
            android:label="@string/title_activity_login"
            android:theme="@style/Theme.EjercicioClase" />
        <activity
            android:name=".ui.theme.PartidosLiga"
            android:exported="false"
            android:label="@string/title_activity_partidos_liga"
            android:theme="@style/Theme.EjercicioClase" />
        <activity
            android:name=".ui.theme.PasarelaPago"
            android:exported="false"
            android:label="@string/title_activity_pasarela_pago"
            android:theme="@style/Theme.EjercicioClase" />
        <activity
            android:name=".ui.theme.Mascot"
            android:exported="false"
            android:label="@string/title_activity_mascot"
            android:theme="@style/Theme.EjercicioClase" />
        <activity
            android:name=".ui.theme.Splash"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.EjercicioClase">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>